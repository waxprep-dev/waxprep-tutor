          "title": "Theory of Evolution",
          "waec_frequency": "high",
          "jamb_frequency": "high",
          "prerequisites": [
            "genetics"
          ],
          "concepts": [
            "evolution",
            "natural selection",
            "survival of the fittest",
            "adaptation",
            " Lamarck's theory",
            "Darwin's theory",
            "speciation",
            "evidence of evolution"
          ],
          "common_misconceptions": [
            "Evolution means humans came from monkeys",
            "Evolution is just a theory in the casual sense"
          ],
          "teaching_note": "Distinguish between Darwin's and Lamarck's theories. Present evidence: fossils, comparative anatomy, embryology, molecular biology."
        }
      ]
    },
    {
      "id": "reproductive_system",
      "title": "Reproductive System and Development",
      "week": 6,
      "subtopics": [
        {
