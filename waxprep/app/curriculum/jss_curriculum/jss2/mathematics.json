{
  "subject": "mathematics",
  "class_level": "JSS2",
  "academic_year": "Junior Secondary",
  "waec_high_priority_topics": [
    "Algebraic Expressions",
    "Simple Equations",
    "Geometry",
    "Angles",
    "Construction",
    "Statistics",
    "Ratio and Proportion"
  ],
  "jamb_high_priority_topics": [],
  "topics": [
    {
      "id": "algebraic_expressions_jss2",
      "title": "Algebraic Expressions",
      "week": 1,
      "subtopics": [
        {
          "id": "expanding_brackets_jss2",
          "title": "Expanding and Simplifying Algebraic Expressions",
          "waec_frequency": "very_high",
          "jamb_frequency": "none",
          "prerequisites": [],
          "concepts": [
            "algebraic expression",
            "like terms",
            "unlike terms",
            "simplifying",
            "expanding brackets",
            "factorization",
            "common factors",
            "substitution"
          ],
          "common_misconceptions": [
            "2x + 3x = 5x²",
            "Brackets can be removed without changing signs"
          ],
          "teaching_note": "Emphasize combining like terms only. Use area models for expansion."
        },
        {
          "id": "simple_equations_jss2",
          "title": "Simple Linear Equations",
          "waec_frequency": "very_high",
          "jamb_frequency": "none",
          "prerequisites": [
            "expanding_brackets_jss2"
          ],
          "concepts": [
            "equation",
            "solution",
            "balance method",
            "transposition",
            "variables on both sides",
            "bracket equations",
            "word problems"
          ],
          "common_misconceptions": [
            "You can move a term without changing its sign",
            "x must always be on the left"
          ],
          "teaching_note": "Use balance analogy. Check solutions by substitution."
        }
      ]
    },
    {
      "id": "geometry_jss2",
      "title": "Geometry",
      "week": 2,
      "subtopics": [
        {
          "id": "angles_parallel",
          "title": "Angles Associated with Parallel Lines",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "algebraic_expressions_jss2"
          ],
          "concepts": [
            "parallel lines",
            "transversal",
            "corresponding angles",
            "alternate angles",
            "interior angles",
            "vertically opposite angles",
            "angles on a straight line",
            "angles at a point"
          ],
          "common_misconceptions": [
            "Corresponding angles are always equal",
            "Alternate angles are on the same side"
          ],
          "teaching_note": "Use Z, F, C patterns for identification. Practice with algebraic angle problems."
        },
        {
          "id": "triangles",
          "title": "Triangles and Their Properties",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "angles_parallel"
          ],
          "concepts": [
            "types of triangles",
            "equilateral",
            "isosceles",
            "scalene",
            "right-angled",
            "angle sum",
            "exterior angle",
            "Pythagoras theorem"
          ],
          "common_misconceptions": [
            "All triangles have a right angle",
            "Isosceles triangles must have one angle at the top"
          ],
          "teaching_note": "Derive angle sum property. Introduce Pythagoras theorem for right-angled triangles."
        }
      ]
    },
    {
      "id": "construction_jss2",
      "title": "Geometric Constructions",
      "week": 3,
      "subtopics": [
        {
          "id": "basic_constructions",
          "title": "Basic Geometric Constructions",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "geometry_jss2"
          ],
          "concepts": [
            "bisector of a line",
            "bisector of an angle",
            "perpendicular lines",
            "parallel lines",
            "constructing triangles",
            "SSS",
            "SAS",
            "ASA"
          ],
          "common_misconceptions": [
            "Construction is the same as drawing",
            "Any compass setting works for all constructions"
          ],
          "teaching_note": "Emphasize leaving construction lines visible. Practice with ruler and compass only."
        }
      ]
    },
    {
      "id": "statistics_jss2",
      "title": "Statistics",
      "week": 4,
      "subtopics": [
        {
          "id": "data_handling",
          "title": "Data Collection and Presentation",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "construction_jss2"
          ],
          "concepts": [
            "data collection",
            "frequency table",
            "tally",
            "bar chart",
            "pie chart",
            "pictogram",
            "mean",
            "median",
            "mode",
            "range"
          ],
          "common_misconceptions": [
            "Mean is always a whole number",
            "Mode must appear most frequently"
          ],
          "teaching_note": "Collect real data from class. Construct charts by hand and discuss interpretation."
        }
      ]
    },
    {
      "id": "ratio_proportion",
      "title": "Ratio, Proportion and Rates",
      "week": 5,
      "subtopics": [
        {
          "id": "ratio",
          "title": "Ratio and Proportion",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "statistics_jss2"
          ],
          "concepts": [
            "ratio",
            "simplifying ratio",
            "dividing in a ratio",
            "proportion",
            "direct proportion",
            "inverse proportion",
            "rate",
            "speed",
            "unitary method"
          ],
          "common_misconceptions": [
            "Ratio is the same as fraction",
            "Doubling one quantity doubles the other in inverse proportion"
          ],
          "teaching_note": "Use real-life examples like recipes and maps. Practice dividing quantities in given ratios."
        }
      ]
    },
    {
      "id": "mensuration_jss2",
      "title": "Mensuration",
      "week": 6,
      "subtopics": [
        {
          "id": "area_perimeter",
          "title": "Area and Perimeter of Plane Shapes",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "ratio_proportion"
          ],
          "concepts": [
            "perimeter",
            "area",
            "rectangle",
            "square",
            "triangle",
            "parallelogram",
            "trapezium",
            "circle",
            "circumference",
            "pi"
          ],
          "common_misconceptions": [
            "Area and perimeter are the same thing",
            "Pi equals exactly 22/7"
          ],
          "teaching_note": "Use grid paper to demonstrate area. Show that pi is approximately 3.14 or 22/7."
        }
      ]
    }
  ]
}