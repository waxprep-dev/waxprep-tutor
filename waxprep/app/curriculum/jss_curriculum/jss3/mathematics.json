{
  "subject": "mathematics",
  "class_level": "JSS3",
  "academic_year": "Junior Secondary",
  "waec_high_priority_topics": [
    "Number Bases",
    "Fractions and Decimals",
    "Approximation and Estimation",
    "Algebraic Expressions",
    "Linear Equations",
    "Simultaneous Equations",
    "Geometry and Trigonometry"
  ],
  "jamb_high_priority_topics": [],
  "topics": [
    {
      "id": "number_bases_jss3",
      "title": "Number Bases",
      "week": 1,
      "subtopics": [
        {
          "id": "bases",
          "title": "Number Bases and Conversion",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [],
          "concepts": [
            "base 10",
            "base 2",
            "base 5",
            "binary",
            "conversion",
            "place value",
            "binary to decimal",
            "decimal to binary",
            "addition in base 2",
            "subtraction in base 2"
          ],
          "common_misconceptions": [
            "Binary only uses digits 0 and 1",
            "Base 5 uses digits 0-5"
          ],
          "teaching_note": "Use multiplication and division methods for conversion. Emphasize place value in different bases."
        }
      ]
    },
    {
      "id": "fractions_decimals_jss3",
      "title": "Fractions and Decimals",
      "week": 2,
      "subtopics": [
        {
          "id": "operations_fractions",
          "title": "Operations with Fractions and Decimals",
          "waec_frequency": "very_high",
          "jamb_frequency": "none",
          "prerequisites": [
            "number_bases_jss3"
          ],
          "concepts": [
            "addition",
            "subtraction",
            "multiplication",
            "division",
            "fractions",
            "decimals",
            "mixed numbers",
            "recurring decimals",
            "BODMAS"
          ],
          "common_misconceptions": [
            "Dividing by a fraction means divide by numerator and denominator",
            "0.333... is exactly equal to 1/3"
          ],
          "teaching_note": "Practice BODMAS with mixed operations. Show relationship between fractions and recurring decimals."
        }
      ]
    },
    {
      "id": "algebra_jss3",
      "title": "Algebra",
      "week": 3,
      "subtopics": [
        {
          "id": "algebraic_fractions",
          "title": "Algebraic Fractions and Equations",
          "waec_frequency": "very_high",
          "jamb_frequency": "none",
          "prerequisites": [
            "fractions_decimals_jss3"
          ],
          "concepts": [
            "algebraic fractions",
            "simplifying",
            "linear equations",
            "equations with brackets",
            "equations with fractions",
            "word problems"
          ],
          "common_misconceptions": [
            "You can cancel terms, not factors",
            "Cross-multiplication works for all equations"
          ],
          "teaching_note": "Emphasize factorization before cancelling. Practice word problems extensively."
        },
        {
          "id": "simultaneous_equations_jss3",
          "title": "Simultaneous Linear Equations",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "algebraic_fractions"
          ],
          "concepts": [
            "simultaneous equations",
            "elimination method",
            "substitution method",
            "graphical method",
            "word problems"
          ],
          "common_misconceptions": [
            "Elimination is always the best method",
            "Graphical method is most accurate"
          ],
          "teaching_note": "Teach students to choose the most efficient method. Check solutions by substitution."
        }
      ]
    },
    {
      "id": "geometry_trig_jss3",
      "title": "Geometry and Trigonometry",
      "week": 4,
      "subtopics": [
        {
          "id": "similar_congruent",
          "title": "Similar and Congruent Triangles",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "algebra_jss3"
          ],
          "concepts": [
            "similar triangles",
            "congruent triangles",
            "SSS",
            "SAS",
            "ASA",
            "RHS",
            "AA",
            "scale factor",
            "area ratio"
          ],
          "common_misconceptions": [
            "Similar triangles are the same size",
            "All equilateral triangles are congruent"
          ],
          "teaching_note": "Use diagrams to distinguish similarity from congruence. Practice ratio problems."
        },
        {
          "id": "pythagoras_trig",
          "title": "Pythagoras Theorem and Trigonometry",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "similar_congruent"
          ],
          "concepts": [
            "Pythagoras theorem",
            "hypotenuse",
            "sine",
            "cosine",
            "tangent",
            "angle of elevation",
            "angle of depression",
            "bearing"
          ],
          "common_misconceptions": [
            "Pythagoras works for all triangles",
            "SOH CAH TOA works for non-right triangles"
          ],
          "teaching_note": "Emphasize right-angled triangles only. Use SOH CAH TOA mnemonic."
        }
      ]
    },
    {
      "id": "statistics_jss3",
      "title": "Statistics",
      "week": 5,
      "subtopics": [
        {
          "id": "data_analysis",
          "title": "Data Analysis and Presentation",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "geometry_trig_jss3"
          ],
          "concepts": [
            "mean",
            "median",
            "mode",
            "range",
            "frequency table",
            "grouped data",
            "cumulative frequency",
            "bar chart",
            "histogram",
            "pie chart"
          ],
          "common_misconceptions": [
            "Mean is always the best average",
            "Histogram and bar chart are the same"
          ],
          "teaching_note": "Discuss when each average is appropriate. Distinguish histogram (continuous) from bar chart (discrete)."
        }
      ]
    }
  ]
}