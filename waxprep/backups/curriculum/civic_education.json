      "id": "citizenship",
      "title": "Citizenship",
      "week": 1,
      "subtopics": [
        {
          "id": "what_is_citizenship",
          "title": "What is Citizenship?",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [],
          "concepts": [
            "citizen",
            "citizenship",
            "Nigerian citizen",
            "birth citizenship",
            "naturalization",
            "dual citizenship",
            "foreigner",
            "alien",
            "deportation"
          ],
          "common_misconceptions": [
            "Being born in Nigeria automatically makes you a citizen",
            "Citizenship cannot be taken away"
          ],
          "teaching_note": "Explain ways of acquiring Nigerian citizenship. Discuss rights that come with citizenship."
        }
      ]
    },
    {
      "id": "rights_duties",
      "title": "Rights and Duties",
      "week": 2,
      "subtopics": [
        {
          "id": "fundamental_rights",
          "title": "Fundamental Human Rights",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "citizenship"
          ],
          "concepts": [
            "human rights",
            "right to life",
            "right to dignity",
            "right to fair hearing",
            "right to freedom of expression",
            "right to religion",
            "right to education",
            "right to vote",
            "Universal Declaration of Human Rights"
          ],
          "common_misconceptions": [
            "Rights have no limits",
            "Children have no rights"
          ],
          "teaching_note": "Discuss the Nigerian Constitution's provisions on rights. Explain that rights come with responsibilities."
        },
        {
          "id": "duties",
          "title": "Duties and Obligations of Citizens",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
