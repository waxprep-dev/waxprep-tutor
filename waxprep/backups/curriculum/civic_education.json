          "concepts": [
            "duties",
            "obedience to law",
            "payment of taxes",
            "voting",
            "defense of country",
            "promotion of national unity",
            "protection of public property"
          ],
          "common_misconceptions": [
            "Only adults have duties",
            "Paying tax is optional"
          ],
          "teaching_note": "Connect rights and duties. Show how citizens' duties contribute to national development."
        }
      ]
    },
    {
      "id": "responsibility",
      "title": "Responsibility",
      "week": 3,
      "subtopics": [
