      "title": "Literary Terms and Devices",
      "week": 1,
      "subtopics": [
        {
          "id": "figures_speech",
          "title": "Figures of Speech and Literary Devices",
          "waec_frequency": "very_high",
          "jamb_frequency": "very_high",
          "prerequisites": [],
          "concepts": [
            "simile",
            "metaphor",
            "personification",
            "hyperbole",
            "euphemism",
            "irony",
            "sarcasm",
            "pun",
            "oxymoron",
            "onomatopoeia",
            "alliteration",
            "assonance"
          ],
          "common_misconceptions": [
            "Figures of speech are only for poetry",
            "All comparisons are similes"
          ],
          "teaching_note": "Illustrate each device with examples from prescribed texts. Have students identify devices in given passages."
        },
        {
          "id": "literary_elements",
          "title": "Elements of Literature",
          "waec_frequency": "very_high",
          "jamb_frequency": "high",
          "prerequisites": [
            "figures_speech"
          ],
          "concepts": [
            "theme",
            "plot",
            "setting",
            "character",
            "characterization",
            "conflict",
            "climax",
            "point of view",
            "narrative technique",
            "atmosphere",
            "tone",
            "mood"
          ],
          "common_misconceptions": [
            "Theme and subject are the same",
            "Plot and story mean the same thing"
          ],
          "teaching_note": "Analyze each element using excerpts from prescribed texts. Show how elements work together to create meaning."
        }
      ]
    },
