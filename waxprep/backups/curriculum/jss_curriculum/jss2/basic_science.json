  "topics": [
    {
      "id": "living_things_environment",
      "title": "Living Things and Their Environment",
      "week": 1,
      "subtopics": [
        {
          "id": "habitat",
          "title": "Habitat and Adaptation",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [],
          "concepts": [
            "habitat",
            "terrestrial",
            "aquatic",
            "arboreal",
            "adaptation",
            "structural adaptation",
            "behavioral adaptation",
            "survival"
          ],
          "common_misconceptions": [
            "Adaptation happens quickly",
            "All organisms in the same habitat look the same"
          ],
          "teaching_note": "Use Nigerian examples: camels in the north, mangroves in the Niger Delta."
        }
      ]
    },
    {
      "id": "reproduction",
      "title": "Reproduction in Organisms",
      "week": 2,
      "subtopics": [
        {
          "id": "types_reproduction",
          "title": "Sexual and Asexual Reproduction",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "living_things_environment"
          ],
          "concepts": [
            "asexual reproduction",
            "sexual reproduction",
            "binary fission",
            "budding",
            "spore formation",
            "fragmentation",
            "pollination",
            "fertilization",
            "seeds"
          ],
          "common_misconceptions": [
            "All plants reproduce asexually",
            "Sexual reproduction requires two organisms"
          ],
          "teaching_note": "Compare advantages and disadvantages. Show examples from flowering plants."
        }
      ]
    },
    {
      "id": "respiratory_system",
      "title": "Respiratory System",
      "week": 3,
      "subtopics": [
        {
          "id": "respiration_concepts",
          "title": "Respiration and Breathing",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "reproduction"
          ],
          "concepts": [
            "respiration",
            "breathing",
            "inhalation",
            "exhalation",
            "lungs",
            "trachea",
            "bronchi",
            "alveoli",
            "oxygen",
            "carbon dioxide",
            "aerobic respiration",
            "anaerobic respiration"
          ],
          "common_misconceptions": [
            "Breathing is the same as respiration",
            "Plants don't respire"
          ],
          "teaching_note": "Distinguish breathing (physical) from respiration (chemical). Demonstrate that plants respire."
        }
      ]
    },
    {
      "id": "circulatory_system",
      "title": "Circulatory System",
      "week": 4,
      "subtopics": [
        {
          "id": "circulation",
