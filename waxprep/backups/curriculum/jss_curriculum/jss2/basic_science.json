          ],
          "concepts": [
            "heart",
            "blood vessels",
            "arteries",
            "veins",
            "capillaries",
            "blood",
            "red blood cells",
            "white blood cells",
            "platelets",
            "plasma",
            "pulse",
            "heartbeat"
          ],
          "common_misconceptions": [
            "Arteries always carry oxygenated blood",
            "The heart creates blood"
          ],
          "teaching_note": "Use diagrams to trace blood flow. Explain the double circulation system."
        }
      ]
    },
    {
      "id": "physical_chemical_changes",
      "title": "Physical and Chemical Changes",
      "week": 5,
      "subtopics": [
        {
          "id": "changes",
          "title": "Differences Between Physical and Chemical Changes",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "circulatory_system"
          ],
          "concepts": [
