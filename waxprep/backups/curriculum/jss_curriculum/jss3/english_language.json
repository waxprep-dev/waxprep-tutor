            "continuous tenses",
            "reported speech",
            "active and passive voice",
            "conditional sentences",
            "relative clauses",
            "participles"
          ],
          "common_misconceptions": [
            "Reported speech just means removing quotation marks",
            "Passive voice is always wrong"
          ],
          "teaching_note": "Teach systematic conversion for reported speech. Show when passive voice is appropriate."
