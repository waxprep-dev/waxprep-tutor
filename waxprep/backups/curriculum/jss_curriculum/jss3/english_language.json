          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [
            "comprehension_jss3"
          ],
          "concepts": [
            "summarization",
            "relevant points",
            "irrelevant details",
            "paraphrasing",
            "synthesis",
            "word limit",
            "own words",
            "coherence"
          ],
          "common_misconceptions": [
            "Summary is just a shorter version of the passage",
            "Copying phrases shows good understanding"
          ],
          "teaching_note": "Emphasize synthesis over copying. Practice identifying truly main points."
        }
      ]
    },
