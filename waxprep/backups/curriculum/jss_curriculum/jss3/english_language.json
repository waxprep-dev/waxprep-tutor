      "title": "Advanced Comprehension",
      "week": 1,
      "subtopics": [
        {
          "id": "reading_skills_jss3",
          "title": "Advanced Reading Comprehension",
          "waec_frequency": "high",
          "jamb_frequency": "none",
          "prerequisites": [],
          "concepts": [
            "critical reading",
            "inference",
            "deduction",
            "author's viewpoint",
            "fact vs opinion",
            "figurative language",
            "context clues",
            "tone",
            "mood"
          ],
          "common_misconceptions": [
            "Every statement in the passage is the author's opinion",
            "Figurative language should be taken literally"
          ],
          "teaching_note": "Practice with complex passages. Teach students to distinguish fact from opinion."
        }
      ]
    },
    {
      "id": "summary_jss3",
      "title": "Summary Writing",
      "week": 2,
      "subtopics": [
