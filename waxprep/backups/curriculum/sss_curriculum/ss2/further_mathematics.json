{
  "subject": "further_mathematics",
  "class_level": "SS2",
  "academic_year": "Senior Secondary",
  "waec_high_priority_topics": [
    "Linear Algebra",
    "Abstract Algebra",
    "Differential Equations",
    "Mechanics",
    "Statistics and Probability",
    "Numerical Methods"
  ],
  "jamb_high_priority_topics": [
    "Matrices",
    "Mechanics",
    "Differential Equations",
    "Probability Distributions"
  ],
  "topics": [
    {
      "id": "linear_algebra",
      "title": "Linear Algebra",
      "week": 1,
      "subtopics": [
        {
          "id": "vector_spaces",
          "title": "Vector Spaces and Linear Transformations",
          "waec_frequency": "high",
          "jamb_frequency": "high",
          "prerequisites": [],
          "concepts": [
            "vector space",
            "linear independence",
            "span",
            "basis",
            "dimension",
            "linear transformation",
            "kernel",
            "image",
            "rank",
            "nullity"
          ],
          "common_misconceptions": [
            "Any set of vectors is a vector space",
            "Linear independence means no vector is zero"
          ],
          "teaching_note": "Start with concrete examples in R² and R³. Introduce abstract concepts gradually."
        },
        {
          "id": "eigenvalues",
          "title": "Eigenvalues and Eigenvectors",
          "waec_frequency": "high",
          "jamb_frequency": "high",
          "prerequisites": [
            "vector_spaces"
          ],
          "concepts": [
            "eigenvalue",
            "eigenvector",
            "characteristic equation",
            "diagonalization",
            "spectral theorem",
            "applications"
          ],
          "common_misconceptions": [
            "Every matrix is diagonalizable",
            "Eigenvalues are always real"
          ],
          "teaching_note": "Show applications to stability analysis and systems of ODEs. Compute eigenvalues for 2x2 and 3x3 matrices."
        }
      ]
    },
    {
      "id": "differential_equations",
      "title": "Differential Equations",
      "week": 2,
      "subtopics": [
        {
          "id": "first_order_ode",
          "title": "First Order Differential Equations",
          "waec_frequency": "very_high",
          "jamb_frequency": "very_high",
          "prerequisites": [
            "linear_algebra"
          ],
          "concepts": [
            "ODE",
            "order",
            "degree",
            "separable",
            "linear first order",
            "integrating factor",
            "exact equations",
            "initial conditions"
          ],
          "common_misconceptions": [
            "All ODEs can be solved analytically",
            "General solution includes all possible solutions"
          ],
          "teaching_note": "Classify ODEs by type. Teach the method of integrating factor for linear equations."
        },
        {
          "id": "second_order_ode",
          "title": "Second Order Linear Differential Equations",
          "waec_frequency": "very_high",
          "jamb_frequency": "very_high",
          "prerequisites": [
            "first_order_ode"
          ],
          "concepts": [
            "homogeneous",
            "auxiliary equation",
            "complementary function",
            "particular integral",
            "D-operator",
            "superposition principle",
            "boundary conditions"
          ],
          "common_misconceptions": [
            "Particular integral is found by guessing randomly",
            "Repeated roots mean no solution"
          ],
          "teaching_note": "Systematic approach: find CF then PI. Show the three cases for auxiliary equation roots."
        }
      ]
    },
    {
      "id": "mechanics",
      "title": "Mechanics",
      "week": 3,
      "subtopics": [
        {
          "id": "kinematics_dynamics",
          "title": "Kinematics and Dynamics of a Particle",
          "waec_frequency": "very_high",
          "jamb_frequency": "very_high",
          "prerequisites": [
            "differential_equations"
          ],
          "concepts": [
            "position vector",
            "velocity vector",
            "acceleration",
            "Newton's laws",
            "momentum",
            "impulse",
            "work",
            "energy",
            "power",
            "conservation of momentum"
          ],
          "common_misconceptions": [
            "Force is always in the direction of motion",
            "Conservation of momentum applies to all collisions"
          ],
          "teaching_note": "Solve problems involving variable forces. Use vector methods for 2D and 3D problems."
        },
        {
          "id": "circular_motion",
          "title": "Circular Motion and Gravitation",
          "waec_frequency": "very_high",
          "jamb_frequency": "high",
          "prerequisites": [
            "kinematics_dynamics"
          ],
          "concepts": [
            "angular velocity",
            "centripetal force",
            "centripetal acceleration",
            "conical pendulum",
            "banked curves",
            "Kepler's laws",
            "orbital motion"
          ],
          "common_misconceptions": [
            "Centripetal force is a new type of force",
            "Satellites don't experience gravity"
          ],
          "teaching_note": "Explain that centripetal force is not a separate force but the net force toward the center."
        }
      ]
    },
    {
      "id": "probability_distributions",
      "title": "Probability Distributions",
      "week": 4,
      "subtopics": [
        {
          "id": "discrete_distributions",
          "title": "Discrete Probability Distributions",
          "waec_frequency": "high",
          "jamb_frequency": "high",
          "prerequisites": [
            "mechanics"
          ],
          "concepts": [
            "random variable",
            "probability mass function",
            "binomial distribution",
            "geometric distribution",
            "Poisson distribution",
            "expectation",
            "variance"
          ],
          "common_misconceptions": [
            "Binomial and Poisson are interchangeable",
            "Expected value is the most likely value"
          ],
          "teaching_note": "Identify conditions for each distribution. Use real-world examples to illustrate applications."
        },
        {
          "id": "continuous_distributions",
          "title": "Continuous Probability Distributions",
          "waec_frequency": "high",
          "jamb_frequency": "high",
          "prerequisites": [
            "discrete_distributions"
          ],
          "concepts": [
            "probability density function",
            "normal distribution",
            "standard normal",
            "Z-score",
            "central limit theorem",
            "confidence intervals"
          ],
          "common_misconceptions": [
            "P(X=x) is meaningful for continuous distributions",
            "Normal distribution applies to all data"
          ],
          "teaching_note": "Emphasize that probability for continuous variables is found as area under the curve. Use standard normal tables."
        }
      ]
    }
  ]
}